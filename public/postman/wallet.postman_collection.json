    {
      "name": "initialize",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. Import Postman's built-in node-forge cryptography library\r",
              "const forge = pm.require(\"npm:node-forge\");\r",
              "\r",
              "// 2. Build the Payload exactly as Java expects it\r",
              "const rawUri = pm.request.url.getPath();\r",
              "const uri = pm.variables.replaceIn(rawUri);\r",
              "const requestTime = Date.now().toString();\r",
              "const nonce = require('uuid').v4();\r",
              "\r",
              "// 3. Extract User ID from the JWT safely\r",
              "const token = pm.environment.get(\"jwt_token\");\r",
              "if (!token) {\r",
              "    throw new Error(\"Missing jwt_token in environment variables\");\r",
              "}\r",
              "\r",
              "const base64Payload = token.split('.')[1];\r",
              "// Using Buffer instead of atob() makes it 100% safe in the Postman sandbox\r",
              "const decodedPayload = JSON.parse(Buffer.from(base64Payload, 'base64').toString('utf8'));\r",
              "const userId = decodedPayload.sub;\r",
              "\r",
              "const payloadToSign = uri + \"|\" + requestTime + \"|\" + nonce + \"|\" + userId;\r",
              "\r",
              "// 4. Perform TRUE RSA-256 Encryption using node-forge!\r",
              "const privateKeyPEM = pm.environment.get(\"rsa_private_key\");\r",
              "const privateKey = forge.pki.privateKeyFromPem(privateKeyPEM);\r",
              "\r",
              "// Create a SHA-256 message digest\r",
              "const md = forge.md.sha256.create();\r",
              "md.update(payloadToSign, 'utf8');\r",
              "\r",
              "// Sign the digest with the Private Key\r",
              "const signatureBytes = privateKey.sign(md);\r",
              "\r",
              "// Convert the binary signature to a Base64 string\r",
              "const signatureBase64 = forge.util.encode64(signatureBytes);\r",
              "\r",
              "// 5. Build the advanced header format\r",
              "const finalSignatureHeader = \"algorithm=RSA256,keyVersion=1,signature=\" + signatureBase64;\r",
              "\r",
              "// 6. Inject the headers dynamically\r",
              "pm.request.headers.add({key: 'Authorization', value: 'Bearer ' + token});\r",
              "pm.request.headers.add({key: 'Request-Time', value: requestTime});\r",
              "pm.request.headers.add({key: 'Nonce', value: nonce});\r",
              "pm.request.headers.add({key: 'Signature', value: finalSignatureHeader});\r",
              "\r",
              "console.log(\"True RSA-256 Signature Generated Successfully with node-forge!\");"
            ],
            "type": "text/javascript",
            "packages": {
              "npm:node-forge": {
                "id": "npm:node-forge"
              }
            },
            "requests": {}
          }
        }
      ],
